{
  "name": "@vanilla-extract/webpack-plugin",
  "version": "2.3.26",
  "description": "Zero-runtime Stylesheets-in-TypeScript",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanilla-extract-css/vanilla-extract.git",
    "directory": "packages/webpack-plugin"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@vanilla-extract/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./loader": {
      "@vanilla-extract/source": "./src/loader.ts",
      "import": "./dist/loader.mjs",
      "require": "./dist/loader.cjs"
    },
    "./next": {
      "@vanilla-extract/source": "./src/next.ts",
      "import": "./dist/next.mjs",
      "require": "./dist/next.cjs"
    },
    "./virtualFileLoader": {
      "@vanilla-extract/source": "./src/virtualFileLoader.ts",
      "import": "./dist/virtualFileLoader.mjs",
      "require": "./dist/virtualFileLoader.cjs"
    },
    "./virtualNextFileLoader": {
      "@vanilla-extract/source": "./src/virtualNextFileLoader.ts",
      "import": "./dist/virtualNextFileLoader.mjs",
      "require": "./dist/virtualNextFileLoader.cjs"
    },
    "./package.json": "./package.json"
  },
  "preconstruct": {
    "entrypoints": [
      "index.ts",
      "loader.ts",
      "virtualFileLoader.ts",
      "next.ts",
      "virtualNextFileLoader.ts"
    ]
  },
  "files": [
    "dist",
    "loader",
    "virtualFileLoader",
    "next",
    "virtualNextFileLoader",
    "extracted.js",
    "vanilla.virtual.css"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/loader.ts src/virtualFileLoader.ts src/next.ts src/virtualNextFileLoader.ts"
  },
  "peerDependencies": {
    "webpack": "^4.30.0 || ^5.20.2"
  },
  "dependencies": {
    "@vanilla-extract/integration": "workspace:^",
    "debug": "^4.3.1",
    "loader-utils": "^2.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.5",
    "webpack": "^5.90.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./loader": {
        "import": "./dist/loader.mjs",
        "require": "./dist/loader.cjs"
      },
      "./next": {
        "import": "./dist/next.mjs",
        "require": "./dist/next.cjs"
      },
      "./virtualFileLoader": {
        "import": "./dist/virtualFileLoader.mjs",
        "require": "./dist/virtualFileLoader.cjs"
      },
      "./virtualNextFileLoader": {
        "import": "./dist/virtualNextFileLoader.mjs",
        "require": "./dist/virtualNextFileLoader.cjs"
      },
      "./package.json": "./package.json"
    }
  }
}
