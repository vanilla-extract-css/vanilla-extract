{
  "name": "@vanilla-extract/css",
  "version": "1.20.1",
  "description": "Zero-runtime Stylesheets-in-TypeScript",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanilla-extract-css/vanilla-extract.git",
    "directory": "packages/css"
  },
  "sideEffects": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@vanilla-extract/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./adapter": {
      "@vanilla-extract/source": "./src/adapter.ts",
      "import": "./dist/adapter.mjs",
      "require": "./dist/adapter.cjs"
    },
    "./disableRuntimeStyles": {
      "@vanilla-extract/source": "./src/disableRuntimeStyles.ts",
      "import": "./dist/disableRuntimeStyles.mjs",
      "require": "./dist/disableRuntimeStyles.cjs"
    },
    "./fileScope": {
      "@vanilla-extract/source": "./src/fileScope.ts",
      "import": "./dist/fileScope.mjs",
      "require": "./dist/fileScope.cjs"
    },
    "./functionSerializer": {
      "@vanilla-extract/source": "./src/functionSerializer.ts",
      "import": "./dist/functionSerializer.mjs",
      "require": "./dist/functionSerializer.cjs"
    },
    "./injectStyles": {
      "@vanilla-extract/source": "./src/injectStyles.ts",
      "import": "./dist/injectStyles.mjs",
      "require": "./dist/injectStyles.cjs"
    },
    "./recipe": {
      "@vanilla-extract/source": "./src/recipe.ts",
      "import": "./dist/recipe.mjs",
      "require": "./dist/recipe.cjs"
    },
    "./transformCss": {
      "@vanilla-extract/source": "./src/transformCss.ts",
      "import": "./dist/transformCss.mjs",
      "require": "./dist/transformCss.cjs"
    },
    "./package.json": "./package.json",
    "./vanilla.virtual.css?*": "./vanilla.virtual.css?*"
  },
  "preconstruct": {
    "entrypoints": [
      "index.ts",
      "recipe.ts",
      "functionSerializer.ts",
      "adapter.ts",
      "transformCss.ts",
      "fileScope.ts",
      "injectStyles.ts",
      "disableRuntimeStyles.ts"
    ]
  },
  "files": [
    "dist",
    "vanilla.virtual.css"
  ],
  "scripts": {
    "build": "tsdown "
  },
  "dependencies": {
    "@emotion/hash": "^0.9.0",
    "@vanilla-extract/private": "workspace:^",
    "css-what": "^6.1.0",
    "csstype": "^3.2.3",
    "dedent": "^1.5.3",
    "deep-object-diff": "^1.1.9",
    "deepmerge": "^4.2.2",
    "lru-cache": "^10.4.3",
    "media-query-parser": "^2.0.2",
    "modern-ahocorasick": "^1.0.0",
    "picocolors": "^1.0.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./adapter": {
        "import": "./dist/adapter.mjs",
        "require": "./dist/adapter.cjs"
      },
      "./disableRuntimeStyles": {
        "import": "./dist/disableRuntimeStyles.mjs",
        "require": "./dist/disableRuntimeStyles.cjs"
      },
      "./fileScope": {
        "import": "./dist/fileScope.mjs",
        "require": "./dist/fileScope.cjs"
      },
      "./functionSerializer": {
        "import": "./dist/functionSerializer.mjs",
        "require": "./dist/functionSerializer.cjs"
      },
      "./injectStyles": {
        "import": "./dist/injectStyles.mjs",
        "require": "./dist/injectStyles.cjs"
      },
      "./recipe": {
        "import": "./dist/recipe.mjs",
        "require": "./dist/recipe.cjs"
      },
      "./transformCss": {
        "import": "./dist/transformCss.mjs",
        "require": "./dist/transformCss.cjs"
      },
      "./package.json": "./package.json",
      "./vanilla.virtual.css?*": "./vanilla.virtual.css?*"
    }
  }
}
