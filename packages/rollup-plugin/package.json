{
  "name": "@vanilla-extract/rollup-plugin",
  "version": "1.5.3",
  "description": "Zero-runtime Stylesheets-in-TypeScript",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanilla-extract-css/vanilla-extract.git",
    "directory": "packages/rollup-plugin"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@vanilla-extract/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@vanilla-extract/integration": "workspace:^",
    "magic-string": "^0.30.17"
  },
  "devDependencies": {
    "@fixtures/themed": "workspace:*",
    "@rollup/plugin-json": "^6.1.0",
    "@vanilla-extract/css": "workspace:^",
    "esbuild": "~0.27.0",
    "rolldown": "1.0.0-beta.27",
    "rollup": "^4.20.0",
    "rollup-plugin-esbuild": "^6.1.1"
  },
  "peerDependencies": {
    "rollup": "^2.0.0 || ^3.0.0 || ^4.0.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  }
}
