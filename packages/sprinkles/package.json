{
  "name": "@vanilla-extract/sprinkles",
  "version": "1.6.5",
  "description": "Zero-runtime atomic CSS framework for vanilla-extract",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanilla-extract-css/vanilla-extract.git",
    "directory": "packages/sprinkles"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@vanilla-extract/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./createRuntimeSprinkles": {
      "@vanilla-extract/source": "./src/createRuntimeSprinkles.ts",
      "import": "./dist/createRuntimeSprinkles.mjs",
      "require": "./dist/createRuntimeSprinkles.cjs"
    },
    "./createUtils": {
      "@vanilla-extract/source": "./src/createUtils.ts",
      "import": "./dist/createUtils.mjs",
      "require": "./dist/createUtils.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/createRuntimeSprinkles.ts src/createUtils.ts"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "^1.0.0"
  },
  "devDependencies": {
    "@vanilla-extract/css": "workspace:^"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./createRuntimeSprinkles": {
        "import": "./dist/createRuntimeSprinkles.mjs",
        "require": "./dist/createRuntimeSprinkles.cjs"
      },
      "./createUtils": {
        "import": "./dist/createUtils.mjs",
        "require": "./dist/createUtils.cjs"
      },
      "./package.json": "./package.json"
    }
  }
}
