{
  "name": "@vanilla-extract/recipes",
  "version": "0.5.7",
  "description": "Create multi-variant styles with a type-safe runtime API, heavily inspired by https://stitches.dev",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanilla-extract-css/vanilla-extract.git",
    "directory": "packages/recipes"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@vanilla-extract/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./createRuntimeFn": {
      "@vanilla-extract/source": "./src/createRuntimeFn.ts",
      "import": "./dist/createRuntimeFn.mjs",
      "require": "./dist/createRuntimeFn.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/createRuntimeFn.ts"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "^1.0.0"
  },
  "devDependencies": {
    "@vanilla-extract/css": "workspace:^"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./createRuntimeFn": {
        "import": "./dist/createRuntimeFn.mjs",
        "require": "./dist/createRuntimeFn.cjs"
      },
      "./package.json": "./package.json"
    }
  }
}
