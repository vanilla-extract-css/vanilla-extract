{
  "name": "@vanilla-extract/integration",
  "description": "Zero-runtime Stylesheets-in-TypeScript",
  "version": "8.0.9",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanilla-extract-css/vanilla-extract.git",
    "directory": "packages/integration"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@vanilla-extract/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@babel/core": "^7.23.9",
    "@babel/plugin-syntax-typescript": "^7.23.3",
    "@vanilla-extract/babel-plugin-debug-ids": "workspace:^",
    "@vanilla-extract/css": "workspace:^",
    "dedent": "^1.5.3",
    "esbuild": "npm:esbuild@>=0.17.6 <0.28.0",
    "find-up": "^5.0.0",
    "javascript-stringify": "^2.0.1",
    "mlly": "^1.4.2"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  }
}
