{
  "name": "@vanilla-extract/babel-plugin-debug-ids",
  "version": "1.2.2",
  "description": "Zero-runtime Stylesheets-in-TypeScript",
  "author": "SEEK",
  "license": "MIT",
  "repository": {
    "type": "git",
