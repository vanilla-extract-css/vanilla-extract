    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@babel/core": "^7.23.9"
  },
  "devDependencies": {
    "@babel/plugin-syntax-typescript": "^7.23.3",
    "@types/babel__core": "^7.20.5"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  }
